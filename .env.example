# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/nismstudy
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/nismstudy

# JWT Secret (Change this to a random string)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Session Secret (Change this to a random string)
SESSION_SECRET=your_session_secret_key_change_this_in_production

# Admin Credentials (Change these!)
ADMIN_EMAIL=admin@nismstudy.com
ADMIN_PASSWORD=Admin@123456

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Quiz Configuration
QUIZ_50_QUESTIONS_TIME=7200
QUIZ_100_QUESTIONS_TIME=10800
PASSING_PERCENTAGE=60




