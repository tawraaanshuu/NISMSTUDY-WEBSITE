# ===================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env.production and update with your production values

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://www.nismstudy.com

# Database Configuration - MongoDB Atlas Production
# Get this from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nismstudy_production?retryWrites=true&w=majority

# JWT Secret - Generate a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_strong_jwt_secret_min_32_characters_production

# Session Secret - Generate a strong random string
SESSION_SECRET=your_super_strong_session_secret_min_32_characters_production

# Admin Credentials - CHANGE THESE IN PRODUCTION!
ADMIN_EMAIL=admin@nismstudy.com
ADMIN_PASSWORD=Your_Very_Strong_Admin_Password_123!

# Razorpay Payment Gateway - PRODUCTION KEYS
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Email Configuration - For notifications
# Option 1: Gmail (Use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_business_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=NISMSTUDY <noreply@nismstudy.com>

# Option 2: SendGrid (Recommended for production)
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=noreply@nismstudy.com

# Option 3: AWS SES (Best for scale)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=ap-south-1
# EMAIL_FROM=noreply@nismstudy.com

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,mp4

# Quiz Configuration
QUIZ_50_QUESTIONS_TIME=7200
QUIZ_100_QUESTIONS_TIME=10800
PASSING_PERCENTAGE=60

# Security Configuration
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# CORS Configuration
ALLOWED_ORIGINS=https://www.nismstudy.com,https://nismstudy.com

# Monitoring & Logging
ENABLE_LOGGING=true
LOG_LEVEL=error
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Payment Configuration
PAYMENT_CURRENCY=INR
TAX_PERCENTAGE=18

# Course Access Duration
DEFAULT_COURSE_DURATION_MONTHS=6

# Features Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_REFERRAL_PROGRAM=false
MAINTENANCE_MODE=false

# API Keys for future integrations
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
FACEBOOK_PIXEL_ID=your_facebook_pixel_id
WHATSAPP_API_KEY=your_whatsapp_business_api_key



